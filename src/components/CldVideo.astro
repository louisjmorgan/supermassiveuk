---
import { Cloudinary } from "@cloudinary/url-gen";
import type { HTMLAttributes } from "astro/types";

const cld = new Cloudinary({
  cloud: {
    cloudName: "dzzhteqkx",
  },
});

const { poster, src, ...props } = Astro.props;
let posterSrc;
if (poster) {
  posterSrc = cld.image(poster);
  if (poster.startsWith("https://")) {
    posterSrc.setDeliveryType("fetch");
  }
}

let vidSrc = cld.video(src);
if (src.startsWith("https://")) {
  vidSrc.setDeliveryType("fetch");
}

interface Props extends HTMLAttributes<"video"> {
  src: string;
  poster?: string;
}
---

<video src={vidSrc.toURL()} poster={poster ? posterSrc?.toURL() : ""} {...props}
></video>
