---
import EnterButton from "./EnterButton.astro";
import WaveHeader from "./WaveHeader.astro";
---

<WaveHeader class="wave">
  <div
    class="w-full flex flex-col items-center break-words scroll-my-16 md:scroll-my-32"
    id="about"
  >
    <div class="w-3/4 sm:w-2/3 md:w-[70ch] flex flex-col items-center m-0 p-0">
      <h1
        class="w-full font-display z-10 text-3xl sm:text-4xl md:text-5xl text-white flex flex-col items-center gap-3 mb-3 md:mb-8 my-12 sm:my-0"
      >
        <span class="font-sans self-start text-l sm:text-2xl md:text-4xl"
          >We are</span
        ><span class="text-white text-4xl xs:text-5xl sm:text-6xl md:text-8xl"
          >SuperMassive</span
        >
      </h1>
      <p
        class="self-end text-l sm:text-xl md:2xl text-white font-sans max-w-[30ch] md:max-w-[40ch] mt-1 md:mt-8"
      >
        Dedicated to bringing exciting interactive art to the UK.
      </p>
    </div>
  </div>
</WaveHeader>
<section class="flex flex-col justify-start items-center w-full">
  <div class="flex flex-col justify-start items-center p-6 sm:p-24 max-w-3xl">
    <!-- <button
      class="text-3xl text-white hover:bg-[#cddc39] px-12 py-12 rounded-2xl font-sans hover:scale-150 transition-all"
    >
      Attend our launch event!</button
    > -->
    <EnterButton color="white">
      <a
        class="font-display text-3xl sm:text-4xl align-middle"
        href="https://www.skiddle.com/whats-on/London/Submarine-Cable-Depot/SuperMassive-Emergence-Day-Tickets/36341285/"
        target="_blank">Attend our launch event!</a
      >
    </EnterButton>
  </div>
</section>

