---
import EnterButton from "./EnterButton.astro";
import WaveHeader from "./WaveHeader.astro";
---

<WaveHeader class="wave" />
<section class="flex flex-col justify-start items-center w-full">
  <div class="flex flex-col justify-start items-center p-5 max-w-3xl">
    <!-- <button
      class="text-3xl text-white hover:bg-[#cddc39] px-12 py-12 rounded-2xl font-sans hover:scale-150 transition-all"
    >
      Attend our launch event!</button
    > -->
    <EnterButton color="white">
      <a
        class="font-display text-4xl"
        href="https://www.skiddle.com/whats-on/London/Submarine-Cable-Depot/SuperMassive-Emergence-Day-Tickets/36341285/"
        target="_blank">Attend our launch event!</a
      >
    </EnterButton>
  </div>
</section>

<style lang="scss">
  section {
  }

  .wave {
    // background: #f0f0f0;
    background: linear-gradient(
      to top,
      black 1%,
      #8a4af3 2%,
      #e91e63,
      #f44336,
      #ff5722,
      #ff9800,
      // #ffc107,
      // #ffeb3b,
      // #cddc39,
      // #8bc34a,
      // #4caf50,
      // #009688,
      // #2196f3,
      // #3f51b5,
      // #673ab7,
    ); /* W3C, IE 10+/ Edge, Firefox 16+, Chrome 26+, Opera 12+, Safari 7+ */
    background-attachment: fixed;
    background-size: 400%;
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .bottom-wave {
    background: linear-gradient(
      to top,
      #e91e63,
      #f44336,
      // #ff5722,
      // #ff9800,
      // #ffc107,
      // #ffeb3b,
      // #cddc39,
      // #8bc34a,
      // #4caf50,
      // #009688,
      // #2196f3,
      // #3f51b5,
      // #673ab7,
      // #8a4af3
    ); /* W3C, IE 10+/ Edge, Firefox 16+, Chrome 26+, Opera 12+, Safari 7+ */
  }
</style>
